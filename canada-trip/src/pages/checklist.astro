---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { checklistCategories } from '../data/checklist';
const totalItems = checklistCategories.reduce((sum, c) => sum + c.items.length, 0);
---

<Layout title="Checklist — Canada Trip" description="Pre-trip checklist for FOSSY 2026 Vancouver.">
  <Nav />
  <main>
    <div class="checklist-hero">
      <div class="container">
        <p class="section-label">Pre-trip Planning</p>
        <h1>Checklist</h1>
      </div>
    </div>

    <div class="container">
      <div class="progress-bar-wrap">
        <div class="progress-meta"><span id="done-count">0</span> / {totalItems} items complete</div>
        <div class="progress-track"><div id="progress-fill" class="progress-fill"></div></div>
      </div>

      <div class="checklist-body">
        {checklistCategories.map(cat => (
          <section class="checklist-section" data-cat={cat.id}>
            <div class="cat-header">
              <h2 class="cat-title">{cat.label}</h2>
              <span class="cat-progress" id={`cat-prog-${cat.id}`}>0 / {cat.items.length}</span>
            </div>
            <ul class="checklist-items">
              {cat.items.map(item => (
                <li class="checklist-item" data-id={item.id}>
                  <label>
                    <input type="checkbox" data-item={item.id} data-cat={cat.id} />
                    <span class="item-label">{item.label}</span>
                  </label>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <div class="checklist-footer">
        <button id="clear-all" class="btn btn-outline">Clear All</button>
        <span class="save-note">✓ Saved automatically in your browser</span>
      </div>
    </div>
  </main>
</Layout>

<script>
  const KEY = 'canada-checklist';
  function load(): Record<string, boolean> { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; } }
  function save(d: Record<string, boolean>) { localStorage.setItem(KEY, JSON.stringify(d)); }

  let state = load();

  function updateProgress() {
    const boxes = document.querySelectorAll<HTMLInputElement>('input[type=checkbox][data-item]');
    const done  = Array.from(boxes).filter(b => b.checked).length;
    const total = boxes.length;
    const countEl = document.getElementById('done-count');
    if (countEl) countEl.textContent = String(done);
    const fillEl = document.getElementById('progress-fill');
    if (fillEl) fillEl.style.width = total > 0 ? `${Math.round(done / total * 100)}%` : '0%';

    const seen = new Set<string>();
    document.querySelectorAll<HTMLElement>('[data-cat]').forEach(sec => {
      const id = sec.dataset.cat!;
      if (seen.has(id)) return; seen.add(id);
      const catBoxes = sec.querySelectorAll<HTMLInputElement>(`input[data-cat="${id}"]`);
      const catDone  = Array.from(catBoxes).filter(b => b.checked).length;
      const el = document.getElementById(`cat-prog-${id}`);
      if (el) el.textContent = `${catDone} / ${catBoxes.length}`;
    });
  }

  document.querySelectorAll<HTMLInputElement>('input[type=checkbox][data-item]').forEach(box => {
    if (state[box.dataset.item!]) { box.checked = true; box.closest('.checklist-item')?.classList.add('done'); }
    box.addEventListener('change', () => {
      const newChecked = box.checked;
      box.checked = !newChecked;
      const requireAuth = (window as any).piiRequireAuth || ((cb: () => void) => cb());
      requireAuth(() => {
        state[box.dataset.item!] = newChecked;
        save(state);
        box.checked = newChecked;
        box.closest('.checklist-item')?.classList.toggle('done', newChecked);
        updateProgress();
      });
    });
  });
  updateProgress();

  document.getElementById('clear-all')?.addEventListener('click', () => {
    const requireAuth = (window as any).piiRequireAuth || ((cb: () => void) => cb());
    requireAuth(() => {
      if (!confirm('Clear all checklist progress?')) return;
      state = {}; save(state);
      document.querySelectorAll<HTMLInputElement>('input[type=checkbox][data-item]').forEach(b => { b.checked = false; b.closest('.checklist-item')?.classList.remove('done'); });
      updateProgress();
    });
  });
</script>

<style>
  .checklist-hero { background: linear-gradient(135deg, var(--ca-red-dark) 0%, var(--ca-maple) 100%); color: white; padding: 2.5rem 0 2rem; }
  .checklist-hero .section-label { color: rgba(255,255,255,0.7); }
  .checklist-hero h1 { color: white; }

  .progress-bar-wrap { padding: 1.5rem 0; }
  .progress-meta { font-size: 0.9rem; color: var(--gray-500); margin-bottom: 0.5rem; }
  .progress-meta #done-count { font-weight: 700; color: var(--ca-red); font-size: 1.1rem; }
  .progress-track { height: 8px; background: var(--gray-200); border-radius: 999px; overflow: hidden; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--ca-red), var(--ca-maple)); border-radius: 999px; transition: width 0.3s ease; width: 0%; }

  .checklist-body { display: flex; flex-direction: column; gap: 1.5rem; }
  .checklist-section { background: white; border-radius: var(--radius-lg); border: 1px solid var(--gray-200); overflow: hidden; }
  .cat-header { display: flex; justify-content: space-between; align-items: center; padding: 0.85rem 1.25rem; background: var(--gray-50); border-bottom: 1px solid var(--gray-200); }
  .cat-title { font-size: 0.95rem; font-weight: 600; font-family: var(--font-sans); }
  .cat-progress { font-size: 0.82rem; color: var(--gray-500); }
  .checklist-items { list-style: none; }
  .checklist-item { border-bottom: 1px solid var(--gray-100); transition: background 0.1s; }
  .checklist-item:last-child { border-bottom: none; }
  .checklist-item:hover { background: var(--gray-50); }
  .checklist-item label { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.7rem 1.25rem; cursor: pointer; }
  .checklist-item input[type=checkbox] { width: 1rem; height: 1rem; accent-color: var(--ca-red); flex-shrink: 0; margin-top: 0.15rem; cursor: pointer; }
  .item-label { font-size: 0.9rem; color: var(--gray-700); line-height: 1.4; }
  .checklist-item.done .item-label { text-decoration: line-through; color: var(--gray-300); }
  .checklist-footer { display: flex; align-items: center; gap: 1.5rem; padding: 1.5rem 0 2rem; flex-wrap: wrap; }
  .save-note { font-size: 0.82rem; color: var(--gray-500); }
</style>
