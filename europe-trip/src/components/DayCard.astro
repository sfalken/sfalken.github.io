---
import type { Day } from '../data/types';

interface Props {
  day: Day;
  currency: string;
}
const { day, currency } = Astro.props;

const dateObj = new Date(day.date + 'T12:00:00');
const weekday = dateObj.toLocaleDateString('en-US', { weekday: 'long' });
const dateStr = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const totalCost = day.activities.reduce((sum, a) => sum + (a.currency === currency ? a.cost : 0), 0);
---

<div class={`day-card card ${day.isConferenceDay ? 'conference-day' : ''} ${day.conferenceTag === 'Flock' ? 'flock-day' : ''} ${day.conferenceTag === 'openSUSECon' ? 'opensuse-day' : ''}`}>
  <div class="day-header">
    <div class="day-date">
      <span class="day-weekday">{weekday}</span>
      <span class="day-datestr">{dateStr}</span>
    </div>
    <div class="day-title-area">
      <h3 class="day-title">{day.title}</h3>
      {day.isConferenceDay && (
        <span class={`tag ${day.conferenceTag === 'Flock' ? 'tag-flock' : 'tag-opensuse'}`}>
          {day.conferenceTag === 'Flock' ? '🐧 Flock' : '🦎 openSUSECon'}
        </span>
      )}
    </div>
  </div>

  <div class="activities">
    {day.activities.map(activity => (
      <div class="activity">
        <div class="activity-name">
          {activity.url
            ? <a href={activity.url} target="_blank" rel="noopener">{activity.name}</a>
            : activity.name}
          {activity.mapsLink && <a href={activity.mapsLink} target="_blank" rel="noopener" class="map-link" title="Open in Maps">🗺️</a>}
        </div>
        <div class="activity-meta">
          <span class="activity-desc">{activity.description}</span>
          <div class="activity-details">
            <span class="activity-duration">⏱ {activity.duration}</span>
            {activity.cost > 0 && (
              <span class="activity-cost">{activity.cost.toLocaleString()} {activity.currency}</span>
            )}
            {activity.cost === 0 && <span class="activity-free">Free</span>}
          </div>
        </div>
      </div>
    ))}
  </div>

  {day.meals && (
    <div class="day-meals">
      <span class="meals-icon">🍽️</span>
      <span>{day.meals}</span>
    </div>
  )}

  {day.notes && (
    <div class="day-notes">
      <span>📌</span>
      <span>{day.notes}</span>
    </div>
  )}
</div>

<style>
  .day-card { display: flex; flex-direction: column; gap: 0.75rem; }
  .conference-day { border-left: 4px solid var(--eu-blue); }
  .flock-day { border-left: 4px solid var(--flock-color); background: linear-gradient(to right, #eff6ff, white 80%); }
  .opensuse-day { border-left: 4px solid var(--opensuse-color); background: linear-gradient(to right, #f0fdf4, white 80%); }

  .day-header { display: flex; gap: 1rem; align-items: flex-start; }
  .day-date {
    flex-shrink: 0;
    width: 52px;
    text-align: center;
    background: var(--eu-red);
    color: white;
    border-radius: 8px;
    padding: 0.4rem;
  }
  .day-weekday { display: block; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.9; }
  .day-datestr { display: block; font-size: 0.9rem; font-weight: 700; }
  .day-title-area { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
  .day-title { font-size: 1.1rem; }

  .activities { display: flex; flex-direction: column; gap: 0.5rem; }
  .activity {
    background: #f9fafb;
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .activity-name { font-weight: 600; font-size: 0.9rem; display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
  .activity-name a { color: var(--eu-dark); }
  .activity-name a:hover { color: var(--eu-red); }
  .map-link { font-size: 0.8rem; opacity: 0.7; }
  .map-link:hover { opacity: 1; text-decoration: none; }
  .activity-desc { font-size: 0.82rem; color: var(--eu-muted); display: block; }
  .activity-details { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; margin-top: 0.15rem; }
  .activity-duration { font-size: 0.78rem; color: var(--eu-muted); }
  .activity-cost {
    font-size: 0.78rem;
    font-weight: 600;
    color: #374151;
    background: #e5e7eb;
    padding: 0.1rem 0.5rem;
    border-radius: 20px;
  }
  .activity-free {
    font-size: 0.78rem;
    font-weight: 600;
    color: #166534;
    background: #dcfce7;
    padding: 0.1rem 0.5rem;
    border-radius: 20px;
  }

  .day-meals, .day-notes {
    display: flex;
    gap: 0.5rem;
    font-size: 0.82rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
  }
  .day-meals { background: #fff7ed; color: #9a3412; }
  .day-notes { background: #f0f9ff; color: #0c4a6e; }
</style>
