---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Trip planner for openSUSECon + Flock to Fedora — Prague & Nuremberg, June 2026', ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://sfalken.github.io/europe-trip';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Europe Trip 2026</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} · Europe Trip 2026`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Europe Trip 2026`} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />}

    <!-- PWA -->
    <link rel="manifest" href={`${base}manifest.json`} />
    <meta name="theme-color" content="#D7141A" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}icon-192.svg`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <style is:global>
      :root {
        --eu-red: #D7141A;
        --eu-gold: #FFCC00;
        --eu-blue: #11457E;
        --eu-dark: #1a1a2e;
        --eu-muted: #6b7280;
        --eu-bg: #fafaf8;
        --eu-surface: #ffffff;
        --eu-border: #e5e7eb;
        --eu-text: #1f2937;

        /* Conference colors */
        --flock-color: #3c6eb4;
        --opensuse-color: #73ba25;

        font-family: 'Jost', system-ui, sans-serif;
        color: var(--eu-text);
        background: var(--eu-bg);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.6;
      }

      h1, h2, h3 { font-family: 'Cormorant Garamond', Georgia, serif; line-height: 1.2; }
      h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; }
      h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 600; }
      h3 { font-size: 1.3rem; font-weight: 600; }

      a { color: var(--eu-red); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

      .eyebrow {
        font-family: 'Jost', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--eu-red);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 1.2rem;
        border-radius: 6px;
        font-family: 'Jost', sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
      }
      .btn-primary { background: var(--eu-red); color: white; }
      .btn-primary:hover { background: #b8111a; text-decoration: none; }
      .btn-outline { background: transparent; border: 2px solid var(--eu-red); color: var(--eu-red); }
      .btn-outline:hover { background: var(--eu-red); color: white; text-decoration: none; }

      .card {
        background: var(--eu-surface);
        border: 1px solid var(--eu-border);
        border-radius: 12px;
        padding: 1.5rem;
        transition: box-shadow 0.2s;
      }
      .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }

      .tag {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        background: var(--eu-border);
        color: var(--eu-muted);
      }
      .tag-red { background: #fee2e2; color: var(--eu-red); }
      .tag-gold { background: #fef9c3; color: #92400e; }
      .tag-blue { background: #dbeafe; color: var(--eu-blue); }
      .tag-flock { background: #dbeafe; color: var(--flock-color); }
      .tag-opensuse { background: #dcfce7; color: #166534; }

      main { flex: 1; padding: 2rem 0 4rem; }

      .page-hero {
        background: linear-gradient(135deg, var(--eu-dark) 0%, var(--eu-blue) 60%, #2d1f6e 100%);
        color: white;
        padding: 4rem 0 3rem;
        position: relative;
        overflow: hidden;
      }
      .page-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          repeating-linear-gradient(45deg, rgba(255,204,0,0.03) 0, rgba(255,204,0,0.03) 1px, transparent 0, transparent 50%);
        background-size: 20px 20px;
      }
      .page-hero .eyebrow { color: var(--eu-gold); }
      .page-hero h1 { color: white; margin: 0.5rem 0 1rem; }
      .page-hero p { color: rgba(255,255,255,0.8); max-width: 600px; font-size: 1.05rem; }

      footer {
        background: var(--eu-dark);
        color: rgba(255,255,255,0.7);
        text-align: center;
        padding: 1.5rem;
        font-size: 0.85rem;
      }
      footer a { color: var(--eu-gold); }

      /* Update banner */
      #update-banner {
        display: none;
        background: var(--eu-blue);
        color: white;
        text-align: center;
        padding: 0.6rem 1rem;
        font-size: 0.85rem;
      }
      #update-banner button {
        background: white;
        color: var(--eu-blue);
        border: none;
        padding: 0.2rem 0.8rem;
        border-radius: 4px;
        cursor: pointer;
        margin-left: 0.5rem;
        font-family: 'Jost', sans-serif;
      }

      /* Stars */
      .stars { color: var(--eu-gold); letter-spacing: -0.1em; }

      /* Grid helpers */
      .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
      .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }

      /* Responsive */
      @media (max-width: 640px) {
        .page-hero { padding: 2.5rem 0 2rem; }
      }
    </style>
  </head>
  <body>
    <div id="update-banner">
      New version available! <button onclick="window.location.reload()">Refresh</button>
    </div>

    <slot name="nav" />
    <slot />

    <footer>
      <p>🇨🇿🇩🇪 Prague + Nuremberg Trip · Solo · June 2026</p>
      <p>
        Built with <a href="https://astro.build" target="_blank">Astro</a> ·
        Hosted on <a href="https://github.com/sfalken/europe-trip" target="_blank">GitHub Pages</a>
      </p>
    </footer>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', async () => {
          try {
            const swUrl = `${new URL('/europe-trip/sw.js', location.origin).href}`;
            const reg = await navigator.serviceWorker.register(swUrl, { scope: '/europe-trip/' });
            reg.addEventListener('updatefound', () => {
              const newWorker = reg.installing;
              if (!newWorker) return;
              newWorker.addEventListener('statechange', () => {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  const banner = document.getElementById('update-banner');
                  if (banner) banner.style.display = 'block';
                }
              });
            });
          } catch (e) {
            // SW registration failed, proceed without it
          }
        });
      }
    </script>
  </body>
</html>
