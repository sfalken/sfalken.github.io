---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { checklistCategories } from '../data/checklist';
const base = import.meta.env.BASE_URL;
---

<Layout title="Checklist" description="Pre-trip planning checklist for Prague and Nuremberg">
  <Nav slot="nav" />

  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Pre-trip Planning</span>
      <h1>Checklist</h1>
      <p>Track everything you need before and during your trip. Progress saves automatically.</p>
    </div>
  </div>

  <main>
    <div class="container">

      <div class="checklist-toolbar">
        <div id="progress-summary" class="progress-summary">
          <span id="progress-text">Loading...</span>
          <div class="progress-bar-wrap">
            <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
          </div>
        </div>
        <button id="clear-all" class="btn btn-outline" style="font-size:0.82rem;">Reset All</button>
      </div>

      <div class="categories" id="categories">
        {checklistCategories.map(cat => (
          <div class="category card" data-category-id={cat.id}>
            <div class="cat-header">
              <div class="cat-title">
                <span class="cat-icon">{cat.icon}</span>
                <h3>{cat.title}</h3>
              </div>
              <span class="cat-count" id={`count-${cat.id}`}></span>
            </div>
            <ul class="checklist">
              {cat.items.map(item => (
                <li class="checklist-item" data-item-id={item.id}>
                  <label class="check-label">
                    <input type="checkbox" class="check-input" data-id={item.id} />
                    <span class="check-box"></span>
                    <span class="check-text">
                      {item.label}
                      {item.priority === 'high' && <span class="priority-dot high" title="High priority"></span>}
                    </span>
                  </label>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>
  </main>
</Layout>

<script define:vars={{ checklistCategories }}>
  const STORAGE_KEY = 'europe-checklist';

  function getState() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    } catch { return {}; }
  }

  function saveState(state) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function updateProgress(state) {
    const allItems = checklistCategories.flatMap(c => c.items);
    const total = allItems.length;
    const done = allItems.filter(i => state[i.id]).length;
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;

    const bar = document.getElementById('progress-bar');
    const text = document.getElementById('progress-text');
    if (bar) bar.style.width = pct + '%';
    if (text) text.textContent = `${done} of ${total} items complete (${pct}%)`;

    checklistCategories.forEach(cat => {
      const catDone = cat.items.filter(i => state[i.id]).length;
      const el = document.getElementById(`count-${cat.id}`);
      if (el) {
        el.textContent = `${catDone}/${cat.items.length}`;
        el.className = `cat-count ${catDone === cat.items.length ? 'complete' : ''}`;
      }
    });
  }

  function init() {
    const state = getState();

    document.querySelectorAll('.check-input').forEach(input => {
      const id = input.dataset.id;
      input.checked = !!state[id];
      const li = input.closest('.checklist-item');
      if (input.checked) li?.classList.add('done');

      input.addEventListener('change', () => {
        const newChecked = input.checked;
        const newState = getState();
        newState[id] = newChecked;
        saveState(newState);
        input.closest('.checklist-item')?.classList.toggle('done', newChecked);
        updateProgress(newState);
      });
    });

    document.getElementById('clear-all')?.addEventListener('click', () => {
      if (!confirm('Reset all checklist items?')) return;
      localStorage.removeItem(STORAGE_KEY);
      document.querySelectorAll('.check-input').forEach(input => {
        input.checked = false;
        input.closest('.checklist-item')?.classList.remove('done');
      });
      updateProgress({});
    });

    updateProgress(state);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .checklist-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 2rem 0 1.5rem;
    flex-wrap: wrap;
  }
  .progress-summary { flex: 1; min-width: 200px; }
  #progress-text { font-size: 0.88rem; color: var(--eu-muted); display: block; margin-bottom: 0.4rem; }
  .progress-bar-wrap {
    height: 8px;
    background: var(--eu-border);
    border-radius: 4px;
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    background: var(--eu-red);
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  .categories { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1rem; }
  .category { }
  .cat-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .cat-title { display: flex; align-items: center; gap: 0.5rem; }
  .cat-icon { font-size: 1.2rem; }
  .cat-title h3 { font-size: 1.05rem; }
  .cat-count {
    font-size: 0.78rem;
    font-weight: 600;
    background: var(--eu-border);
    color: var(--eu-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }
  .cat-count.complete { background: #dcfce7; color: #166534; }

  .checklist { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }
  .checklist-item { }
  .check-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    transition: background 0.1s;
  }
  .check-label:hover { background: #f9fafb; }
  .check-input { display: none; }
  .check-box {
    width: 18px;
    height: 18px;
    border: 2px solid var(--eu-border);
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 2px;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .check-input:checked ~ .check-box {
    background: var(--eu-red);
    border-color: var(--eu-red);
  }
  .check-input:checked ~ .check-box::after {
    content: '✓';
    color: white;
    font-size: 11px;
    font-weight: 700;
  }
  .check-text { font-size: 0.9rem; flex: 1; display: flex; align-items: center; gap: 0.5rem; }
  .checklist-item.done .check-text { text-decoration: line-through; color: var(--eu-muted); }
  .priority-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .priority-dot.high { background: var(--eu-red); }
</style>
