---
import type { CityData } from '../data/types';
import HotelCard from './HotelCard.astro';
import RestaurantCard from './RestaurantCard.astro';
import DayCard from './DayCard.astro';
import MapSection from './MapSection.astro';

interface Props {
  city: CityData;
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}
const { city, prev, next } = Astro.props;
---

<section class="city-hero">
  <div class="container">
    <p class="section-label">{city.country}</p>
    <h1>{city.name}</h1>
  </div>
</section>

<div class="container">
  <!-- Map -->
  <section class="section">
    <MapSection
      points={city.mapPoints}
      center={city.coordinates}
      zoom={13}
      title="City Map"
    />
  </section>

  <!-- Itinerary -->
  <section class="section">
    <p class="section-label">Itinerary</p>
    <h2>Day by Day</h2>
    <div class="grid-2" style="margin-top:1rem;">
      {city.days.map((day, i) => <DayCard day={day} index={i} />)}
    </div>
  </section>

  <!-- Ice Cream Selfie Spots -->
  {city.iceCreamSpots && city.iceCreamSpots.length > 0 && (
    <section class="section">
      <p class="section-label">Conference Tradition</p>
      <h2>🍦 Ice Cream Selfie Spots</h2>
      <p style="color:var(--gray-500);margin:.5rem 0 1rem;">Mariatta's ice cream selfie tradition: one scoop per conference day (and extra scoops because Austin).</p>
      <div class="grid-2">
        {city.iceCreamSpots.map(spot => (
          <div class="card icecream-card">
            <div class="ic-header">
              <span class="ic-emoji">🍦</span>
              <div>
                <h3 class="ic-name">{spot.name}</h3>
                <p class="ic-address">{spot.address}</p>
              </div>
            </div>
            <p class="ic-note">{spot.photoNote}</p>
            <div class="ic-flavors">
              <span class="flavor-label">Signature flavors:</span>
              {spot.signatureFlavors.map((f, i) => (
                <span>{f}{i < spot.signatureFlavors.length - 1 ? ' · ' : ''}</span>
              ))}
            </div>
            <a href={spot.mapsLink} target="_blank" rel="noopener" class="btn btn-outline" style="margin-top:.75rem;align-self:flex-start;">📍 Map</a>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Hotels -->
  <section class="section">
    <p class="section-label">Where to Stay</p>
    <h2>Hotel Recommendations</h2>
    <div class="grid-2" style="margin-top:1rem;">
      {city.hotels.map(hotel => <HotelCard hotel={hotel} />)}
    </div>
  </section>

  <!-- Restaurants -->
  <section class="section">
    <p class="section-label">Where to Eat</p>
    <h2>Restaurant Picks</h2>
    <div class="grid-2" style="margin-top:1rem;">
      {city.restaurants.map(r => <RestaurantCard restaurant={r} />)}
    </div>
  </section>

  <!-- Prev/Next navigation -->
  {(prev || next) && (
    <nav class="city-nav">
      {prev
        ? <a href={prev.href} class="btn btn-outline">← {prev.label}</a>
        : <span></span>
      }
      {next && <a href={next.href} class="btn btn-primary">{next.label} →</a>}
    </nav>
  )}
</div>

<style>
  .city-hero {
    background: linear-gradient(135deg, var(--tx-red) 0%, #8b0621 100%);
    color: white;
    padding: 2.5rem 0 2rem;
  }
  .city-hero .section-label { color: rgba(255,255,255,0.7); }
  .city-hero h1 { color: white; margin-top: 0.25rem; }

  .icecream-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    border-top: 3px solid #f59e0b;
  }
  .ic-header { display: flex; gap: 0.75rem; align-items: flex-start; }
  .ic-emoji { font-size: 1.75rem; line-height: 1; flex-shrink: 0; }
  .ic-name { font-size: 1.05rem; margin-bottom: 0.15rem; }
  .ic-address { font-size: 0.82rem; color: var(--gray-500); }
  .ic-note { font-size: 0.88rem; color: var(--gray-700); line-height: 1.5; }
  .ic-flavors { font-size: 0.82rem; color: var(--gray-500); }
  .flavor-label { font-weight: 600; color: var(--gray-700); margin-right: 0.25rem; }

  .city-nav {
    display: flex;
    justify-content: space-between;
    padding: 2rem 0 1rem;
    gap: 1rem;
  }
</style>
