---
import type { Day } from '../data/types';

export interface Props {
  day: Day;
  index: number;
}

const { day, index } = Astro.props;
const totalCost = day.activities.reduce((sum, a) => sum + a.cost, 0);
---

<div class={`card day-card ${day.isConferenceDay ? 'conference-day' : ''}`}>
  <div class="day-header">
    {day.isConferenceDay && (
      <div class="conf-banner">
        <span>💻 DevConf.US Day</span>
      </div>
    )}
    <div class="day-meta">
      <span class="day-label">{day.label}</span>
      <span class="day-date">{day.date}</span>
    </div>
    <h3 class="day-theme">{day.theme}</h3>
    {totalCost > 0 && (
      <div class="day-cost">Est. spend: <strong>${totalCost}</strong></div>
    )}
  </div>

  <ul class="activities">
    {day.activities.map(activity => (
      <li class="activity">
        <div class="activity-top">
          <span class="activity-name">{activity.name}</span>
          <span class="activity-duration">{activity.duration}</span>
        </div>
        <p class="activity-desc">{activity.description}</p>
        <div class="activity-bottom">
          {activity.cost > 0 ? (
            <span class="activity-cost">${activity.cost}</span>
          ) : (
            <span class="activity-free">Free</span>
          )}
          <div class="activity-links">
            {activity.website && (
              <a href={activity.website} target="_blank" rel="noopener" class="activity-link">Website</a>
            )}
            {activity.mapsLink && (
              <a href={activity.mapsLink} target="_blank" rel="noopener" class="activity-link">Map</a>
            )}
          </div>
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .day-card {
    overflow: visible;
  }

  .day-header {
    padding: 1.1rem 1.25rem 0.9rem;
    border-bottom: 1px solid var(--gray-100);
    background: var(--gray-50);
  }

  .conference-day .day-header {
    background: var(--usa-blue-pale);
    border-bottom-color: #c7c6e8;
  }

  .conf-banner {
    background: var(--usa-blue);
    color: white;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 0.65rem;
  }

  .day-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
  }

  .day-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--usa-red);
  }

  .day-date {
    font-size: 0.82rem;
    color: var(--gray-500);
  }

  .day-theme {
    font-size: 1.2rem;
    color: var(--gray-900);
    margin-bottom: 0.3rem;
  }

  .day-cost {
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .day-cost strong { color: var(--usa-red); }

  .activities {
    list-style: none;
    padding: 0.5rem 0;
  }

  .activity {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--gray-100);
  }
  .activity:last-child { border-bottom: none; }

  .activity-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }

  .activity-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--gray-900);
    line-height: 1.3;
  }

  .activity-duration {
    font-size: 0.75rem;
    color: var(--gray-500);
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .activity-desc {
    font-size: 0.85rem;
    color: var(--gray-700);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .activity-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .activity-cost {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--usa-red);
    background: var(--usa-red-pale);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .activity-free {
    font-size: 0.78rem;
    color: #16a34a;
    background: #f0fdf4;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .activity-links {
    display: flex;
    gap: 0.4rem;
  }

  .activity-link {
    font-size: 0.78rem;
    color: var(--usa-blue);
    text-decoration: underline;
  }
  .activity-link:hover { color: var(--usa-red); }
</style>
