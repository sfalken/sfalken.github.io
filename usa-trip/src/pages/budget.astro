---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { budgetCategories } from '../data/budget';

const base = '/usa-trip';
const categoriesJson = JSON.stringify(budgetCategories);

const totalEstimated = budgetCategories.reduce(
  (sum, cat) => sum + cat.items.reduce((s, item) => s + item.estimated, 0),
  0
);
---

<Layout title="Budget — USA Trip 2026" description="Budget tracker for the Boston DevConf.US trip.">
  <Nav />
  <main>
    <div class="budget-hero">
      <div class="container">
        <p class="section-label">Finance</p>
        <h1>Trip Budget</h1>
        <p class="hero-sub">All amounts in USD · Track estimated vs. actual spending.</p>
      </div>
    </div>

    <section class="section">
      <div class="container">

        <!-- Summary Cards -->
        <div class="summary-grid">
          <div class="summary-card card">
            <span class="sum-label">Estimated Total</span>
            <span class="sum-value" id="est-total">${totalEstimated.toLocaleString()}</span>
            <span class="sum-sub">pre-trip estimate</span>
          </div>
          <div class="summary-card card">
            <span class="sum-label">Actual Spent</span>
            <span class="sum-value" id="actual-total">$0</span>
            <span class="sum-sub">from expense log</span>
          </div>
          <div class="summary-card card">
            <span class="sum-label">Remaining</span>
            <span class="sum-value" id="remaining-total">${totalEstimated.toLocaleString()}</span>
            <span class="sum-sub">estimated – actual</span>
          </div>
        </div>

        <!-- Charts -->
        <div class="charts-grid">
          <div class="card chart-card">
            <h3>Estimated vs Actual by Category</h3>
            <div class="chart-wrap">
              <canvas id="bar-chart"></canvas>
            </div>
          </div>
          <div class="card chart-card">
            <h3>Spending by Category</h3>
            <div class="chart-wrap chart-wrap-sm">
              <canvas id="donut-chart"></canvas>
            </div>
          </div>
        </div>

        <!-- Budget Table -->
        <div class="card" style="margin-top:1.5rem;">
          <div class="table-header">
            <h3>Budget Breakdown</h3>
          </div>
          <div class="budget-table">
            {budgetCategories.map(cat => (
              <div class="budget-category">
                <div class="bcat-header">
                  <span class="bcat-icon">{cat.icon}</span>
                  <span class="bcat-label">{cat.label}</span>
                  <span class="bcat-est">
                    Est: <strong>${cat.items.reduce((s, i) => s + i.estimated, 0).toLocaleString()}</strong>
                  </span>
                </div>
                {cat.items.map(item => (
                  <div class="budget-item">
                    <div class="bi-info">
                      <span class="bi-label">{item.label}</span>
                      {item.note && <span class="bi-note">{item.note}</span>}
                    </div>
                    <div class="bi-amounts">
                      <span class="bi-est">${item.estimated}</span>
                      <span class="bi-actual" data-item-id={item.id} id={`actual-${item.id}`}>$0</span>
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- Recent Expenses -->
        <div class="card" style="margin-top:1.5rem;">
          <div class="table-header">
            <h3>Recent Expenses</h3>
            <a href={`${base}/log/`} class="btn btn-primary" style="font-size:0.82rem;padding:0.35rem 0.85rem;">+ Add Expense</a>
          </div>
          <div id="expense-log">
            <div class="empty-log">No expenses yet. <a href={`${base}/log/`}>Log your first expense →</a></div>
          </div>
        </div>

      </div>
    </section>

    <!-- Floating add button -->
    <a href={`${base}/log/`} class="fab" title="Log expense">+</a>
  </main>
</Layout>

<!-- Chart.js -->
<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>

<script is:inline define:vars={{ categoriesJson, totalEstimated }}>
  const EXPENSE_KEY = 'usa-expenses';
  const categories = JSON.parse(categoriesJson);

  function loadExpenses() {
    try { return JSON.parse(localStorage.getItem(EXPENSE_KEY) || '[]'); } catch { return []; }
  }

  function formatUSD(n) {
    return '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function init() {
    const expenses = loadExpenses();

    // Compute actual per category
    const actualByCat = {};
    expenses.forEach(exp => {
      actualByCat[exp.category] = (actualByCat[exp.category] || 0) + Number(exp.amount);
    });

    const totalActual = expenses.reduce((s, e) => s + Number(e.amount), 0);

    // Update summary cards
    document.getElementById('actual-total').textContent = formatUSD(totalActual);
    document.getElementById('remaining-total').textContent = formatUSD(totalEstimated - totalActual);

    // Update item-level actual (by matching category id)
    categories.forEach(cat => {
      cat.items.forEach(item => {
        const el = document.getElementById('actual-' + item.id);
        if (el) el.textContent = '$0';
      });
    });

    // Bar chart
    const catLabels = categories.map(c => c.label);
    const estData = categories.map(c => c.items.reduce((s, i) => s + i.estimated, 0));
    const actData = categories.map(c => actualByCat[c.id] || 0);

    const barCtx = document.getElementById('bar-chart');
    if (barCtx && window.Chart) {
      if (barCtx._chart) barCtx._chart.destroy();
      barCtx._chart = new Chart(barCtx, {
        type: 'bar',
        data: {
          labels: catLabels,
          datasets: [
            { label: 'Estimated ($)', data: estData, backgroundColor: 'rgba(60,59,110,0.7)', borderRadius: 4 },
            { label: 'Actual ($)', data: actData, backgroundColor: 'rgba(178,34,52,0.7)', borderRadius: 4 },
          ],
        },
        options: {
          responsive: true,
          plugins: { legend: { position: 'top' } },
          scales: { y: { beginAtZero: true, ticks: { callback: v => '$' + v } } },
        },
      });
    }

    // Donut chart
    const donutCtx = document.getElementById('donut-chart');
    if (donutCtx && window.Chart) {
      if (donutCtx._chart) donutCtx._chart.destroy();
      const colors = ['#B22234','#3C3B6E','#f97316','#22c55e','#a855f7','#ec4899','#f59e0b','#06b6d4','#8b5cf6','#64748b','#84cc16'];
      donutCtx._chart = new Chart(donutCtx, {
        type: 'doughnut',
        data: {
          labels: catLabels,
          datasets: [{ data: estData, backgroundColor: colors, borderWidth: 1 }],
        },
        options: {
          responsive: true,
          plugins: { legend: { position: 'right', labels: { font: { size: 11 } } } },
        },
      });
    }

    // Expense log
    const logEl = document.getElementById('expense-log');
    if (expenses.length === 0) {
      logEl.innerHTML = '<div class="empty-log">No expenses yet. <a href="/usa-trip/log/">Log your first expense →</a></div>';
    } else {
      const recent = [...expenses].reverse().slice(0, 10);
      logEl.innerHTML = `<table class="exp-table">
        <thead><tr><th>Date</th><th>Category</th><th>Description</th><th>Amount</th><th></th></tr></thead>
        <tbody>
          ${recent.map((e, ri) => {
            const idx = expenses.length - 1 - ri;
            return `<tr>
              <td>${e.date || '—'}</td>
              <td>${e.category || '—'}</td>
              <td>${e.label || '—'}</td>
              <td class="exp-amt">${formatUSD(e.amount)}</td>
              <td><button class="exp-del-btn" data-index="${idx}">✕</button></td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>`;

      logEl.querySelectorAll('.exp-del-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const requireAuth = window.piiRequireAuth || (cb => cb());
          requireAuth(() => {
            const all = loadExpenses();
            all.splice(Number(btn.dataset.index), 1);
            localStorage.setItem(EXPENSE_KEY, JSON.stringify(all));
            init();
          });
        });
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      // Wait for Chart.js to load
      const waitForChart = setInterval(() => {
        if (window.Chart) { clearInterval(waitForChart); init(); }
      }, 100);
    });
  } else {
    const waitForChart = setInterval(() => {
      if (window.Chart) { clearInterval(waitForChart); init(); }
    }, 100);
  }
</script>

<style>
  .budget-hero {
    background: linear-gradient(135deg, var(--usa-blue) 0%, #2a2950 100%);
    color: white;
    padding: 2.5rem 0 2rem;
  }
  .budget-hero .section-label { color: rgba(255,255,255,0.65); }
  .budget-hero h1 { color: white; margin-bottom: 0.4rem; }
  .hero-sub { color: rgba(255,255,255,0.75); }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .summary-card {
    padding: 1.25rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sum-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
  }

  .sum-value {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--usa-blue);
  }

  .sum-sub { font-size: 0.75rem; color: var(--gray-500); }

  .charts-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .chart-card { padding: 1.25rem; }
  .chart-card h3 { font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600; margin-bottom: 1rem; color: var(--gray-700); }

  .chart-wrap { position: relative; height: 280px; }
  .chart-wrap-sm { height: 260px; }

  .table-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .table-header h3 { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 600; }

  .budget-category {
    border-bottom: 1px solid var(--gray-100);
  }
  .budget-category:last-child { border-bottom: none; }

  .bcat-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.25rem 0.5rem;
    background: var(--gray-50);
  }

  .bcat-icon { font-size: 1rem; }
  .bcat-label { font-weight: 600; font-size: 0.85rem; flex: 1; }
  .bcat-est { font-size: 0.8rem; color: var(--gray-500); }
  .bcat-est strong { color: var(--usa-blue); }

  .budget-item {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 1.25rem 0.55rem 2.5rem;
    border-top: 1px solid var(--gray-50);
  }

  .bi-info { flex: 1; }
  .bi-label { font-size: 0.85rem; color: var(--gray-800); display: block; }
  .bi-note { font-size: 0.75rem; color: var(--gray-500); display: block; margin-top: 0.15rem; }

  .bi-amounts { display: flex; gap: 1rem; align-items: center; flex-shrink: 0; }
  .bi-est { font-size: 0.82rem; color: var(--gray-500); }
  .bi-actual { font-size: 0.82rem; font-weight: 600; color: var(--usa-red); }

  .empty-log {
    padding: 1.5rem;
    text-align: center;
    color: var(--gray-500);
    font-size: 0.9rem;
  }

  .exp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .exp-table th {
    text-align: left;
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-500);
    border-bottom: 1px solid var(--gray-100);
  }

  .exp-table td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--gray-50);
    color: var(--gray-700);
  }

  .exp-amt { font-weight: 600; color: var(--usa-red); }

  .exp-del-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--gray-400);
    font-size: 0.8rem;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }
  .exp-del-btn:hover { background: var(--gray-100); color: var(--usa-red); }

  .fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--usa-red);
    color: white;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(178,34,52,0.4);
    text-decoration: none;
    line-height: 1;
    z-index: 50;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .fab:hover { transform: scale(1.1); box-shadow: 0 6px 16px rgba(178,34,52,0.5); text-decoration: none; color: white; }

  @media (max-width: 768px) {
    .charts-grid { grid-template-columns: 1fr; }
    .summary-grid { grid-template-columns: 1fr; }
  }
</style>
