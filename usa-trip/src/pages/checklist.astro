---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { checklistCategories } from '../data/checklist';

const totalItems = checklistCategories.reduce((sum, cat) => sum + cat.items.length, 0);
const categoriesJson = JSON.stringify(checklistCategories);
---

<Layout title="Checklist — USA Trip 2026" description="Pre-trip planning checklist for DevConf.US Boston 2026.">
  <Nav />
  <main>
    <div class="checklist-hero">
      <div class="container">
        <p class="section-label">Planning</p>
        <h1>Trip Checklist</h1>
        <p class="hero-sub">Track everything you need to do before Boston.</p>
      </div>
    </div>

    <section class="section">
      <div class="container">
        <!-- Progress Bar -->
        <div class="progress-card card">
          <div class="progress-header">
            <div>
              <span class="progress-label">Overall Progress</span>
              <span class="progress-count" id="progress-count">0 / {totalItems} complete</span>
            </div>
            <button class="btn btn-outline" id="reset-btn" style="font-size:0.8rem;padding:0.3rem 0.75rem;">Reset All</button>
          </div>
          <div class="progress-bar-wrap">
            <div class="progress-bar" id="progress-bar" style="width:0%"></div>
          </div>
          <div class="progress-pct" id="progress-pct">0% done</div>
        </div>

        <!-- Categories -->
        <div id="checklist-container" class="checklist-container">
          {checklistCategories.map(category => (
            <div class="cat-card card" data-category={category.id}>
              <div class="cat-header" data-toggle={category.id}>
                <div class="cat-title-row">
                  <h2 class="cat-title">{category.label}</h2>
                  <span class="cat-progress-badge" id={`cat-badge-${category.id}`}>
                    0/{category.items.length}
                  </span>
                </div>
                <span class="cat-chevron">▼</span>
              </div>
              <ul class="cat-items" id={`cat-items-${category.id}`}>
                {category.items.map(item => (
                  <li class="check-item" data-id={item.id} data-category={category.id}>
                    <label class="check-label">
                      <input type="checkbox" class="check-input" data-id={item.id} />
                      <span class="check-box"></span>
                      <span class="check-text">{item.label}</span>
                    </label>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline define:vars={{ categoriesJson }}>
  const STORAGE_KEY = 'usa-checklist';
  const categories = JSON.parse(categoriesJson);
  const totalItems = categories.reduce((s, c) => s + c.items.length, 0);

  function loadState() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch { return {}; }
  }

  function saveState(state) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function updateProgress(state) {
    const done = Object.values(state).filter(Boolean).length;
    const pct = totalItems ? Math.round((done / totalItems) * 100) : 0;
    document.getElementById('progress-count').textContent = `${done} / ${totalItems} complete`;
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '% done';

    categories.forEach(cat => {
      const catDone = cat.items.filter(i => state[i.id]).length;
      const badge = document.getElementById('cat-badge-' + cat.id);
      if (badge) {
        badge.textContent = `${catDone}/${cat.items.length}`;
        badge.className = 'cat-progress-badge' + (catDone === cat.items.length && cat.items.length > 0 ? ' complete' : '');
      }
    });
  }

  function init() {
    const state = loadState();

    // Set checkbox states
    document.querySelectorAll('.check-input').forEach(input => {
      const id = input.dataset.id;
      input.checked = !!state[id];
      input.closest('li').classList.toggle('checked', !!state[id]);
    });

    updateProgress(state);

    // Checkbox change handler
    document.querySelectorAll('.check-input').forEach(input => {
      input.addEventListener('change', () => {
        const newChecked = input.checked;
        const state = loadState();
        state[input.dataset.id] = newChecked;
        saveState(state);
        input.closest('li').classList.toggle('checked', newChecked);
        updateProgress(state);
      });
    });

    // Toggle categories
    document.querySelectorAll('.cat-header').forEach(header => {
      header.addEventListener('click', () => {
        const id = header.dataset.toggle;
        const items = document.getElementById('cat-items-' + id);
        const chevron = header.querySelector('.cat-chevron');
        const isOpen = items.style.display !== 'none';
        items.style.display = isOpen ? 'none' : 'block';
        chevron.style.transform = isOpen ? 'rotate(-90deg)' : 'rotate(0deg)';
      });
    });

    // Reset
    document.getElementById('reset-btn').addEventListener('click', () => {
      if (!confirm('Reset all checklist items?')) return;
      const empty = {};
      saveState(empty);
      document.querySelectorAll('.check-input').forEach(i => { i.checked = false; });
      document.querySelectorAll('.check-item').forEach(i => i.classList.remove('checked'));
      updateProgress(empty);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .checklist-hero {
    background: linear-gradient(135deg, var(--usa-blue) 0%, #2a2950 100%);
    color: white;
    padding: 2.5rem 0 2rem;
  }
  .checklist-hero .section-label { color: rgba(255,255,255,0.65); }
  .checklist-hero h1 { color: white; margin-bottom: 0.4rem; }
  .hero-sub { color: rgba(255,255,255,0.75); }

  .progress-card {
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.85rem;
  }

  .progress-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-bottom: 0.2rem;
  }

  .progress-count {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--gray-900);
  }

  .progress-bar-wrap {
    background: var(--gray-100);
    border-radius: 999px;
    height: 10px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .progress-bar {
    height: 100%;
    background: linear-gradient(to right, var(--usa-red), var(--usa-blue));
    border-radius: 999px;
    transition: width 0.3s ease;
  }

  .progress-pct {
    font-size: 0.8rem;
    color: var(--gray-500);
    text-align: right;
  }

  .checklist-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cat-card {
    overflow: hidden;
  }

  .cat-header {
    padding: 1rem 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-100);
    user-select: none;
  }
  .cat-header:hover { background: var(--gray-100); }

  .cat-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cat-title {
    font-size: 1rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--gray-900);
  }

  .cat-progress-badge {
    background: var(--gray-100);
    color: var(--gray-600);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }
  .cat-progress-badge.complete {
    background: #dcfce7;
    color: #15803d;
  }

  .cat-chevron {
    color: var(--gray-400);
    font-size: 0.7rem;
    transition: transform 0.2s;
  }

  .cat-items {
    list-style: none;
    padding: 0.25rem 0;
  }

  .check-item {
    border-bottom: 1px solid var(--gray-50);
    transition: background 0.15s;
  }
  .check-item:last-child { border-bottom: none; }
  .check-item.checked { background: #f0fdf4; }

  .check-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
  }
  .check-label:hover { background: var(--gray-50); }

  .check-input { display: none; }

  .check-box {
    width: 18px;
    height: 18px;
    border: 2px solid var(--gray-300);
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 0.1rem;
    transition: all 0.15s;
    position: relative;
  }

  .check-input:checked ~ .check-box {
    background: var(--usa-red);
    border-color: var(--usa-red);
  }

  .check-input:checked ~ .check-box::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 1px;
    width: 6px;
    height: 10px;
    border: 2px solid white;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .check-text {
    font-size: 0.88rem;
    color: var(--gray-700);
    line-height: 1.4;
  }

  .checked .check-text {
    text-decoration: line-through;
    color: var(--gray-400);
  }
</style>
