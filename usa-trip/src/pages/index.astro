---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const base = '/usa-trip';
---

<Layout title="USA Trip — DevConf.US Boston 2026" description="Solo trip to Boston, MA for DevConf.US conference, September 22–26, 2026.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <p class="hero-eyebrow">September 22–26, 2026</p>
        <h1 class="hero-title">Boston, MA</h1>
        <p class="hero-subtitle">Solo trip · DevConf.US Conference · Sightseeing</p>
        <div class="hero-actions">
          <a href={`${base}/boston/`} class="btn btn-primary">Explore Boston →</a>
          <a href={`${base}/checklist/`} class="btn btn-outline-white">Planning Checklist</a>
        </div>
      </div>
    </section>

    <!-- Quick Stats -->
    <section class="section stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-card card">
            <span class="stat-icon">📅</span>
            <span class="stat-value">5 days</span>
            <span class="stat-label">Sep 22–26</span>
          </div>
          <div class="stat-card card">
            <span class="stat-icon">🏙️</span>
            <span class="stat-value">1 city</span>
            <span class="stat-label">Boston, MA</span>
          </div>
          <div class="stat-card card">
            <span class="stat-icon">💻</span>
            <span class="stat-value">DevConf.US</span>
            <span class="stat-label">Sep 24–25 @ BU</span>
          </div>
          <div class="stat-card card">
            <span class="stat-icon">✈️</span>
            <span class="stat-value">Logan (BOS)</span>
            <span class="stat-label">Airport</span>
          </div>
          <div class="stat-card card">
            <span class="stat-icon">💰</span>
            <span class="stat-value">~$1,953</span>
            <span class="stat-label">Est. Total Budget</span>
          </div>
          <div class="stat-card card">
            <span class="stat-icon">🍦</span>
            <span class="stat-value">5 spots</span>
            <span class="stat-label">Ice Cream Selfies</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Trip Overview -->
    <section class="section section-alt">
      <div class="container">
        <p class="section-label">Trip Overview</p>
        <h2>Your Boston Itinerary</h2>
        <div class="overview-grid">
          <div class="overview-day card">
            <div class="ov-date">Sep 22 · Day 1</div>
            <h3>Arrival & Beacon Hill</h3>
            <p>Fly into Logan, check in, and explore historic Beacon Hill. Dinner at the iconic Regina Pizzeria in the North End.</p>
          </div>
          <div class="overview-day card">
            <div class="ov-date">Sep 23 · Day 2</div>
            <h3>Freedom Trail & Waterfront</h3>
            <p>Walk the 2.5-mile Freedom Trail, lunch at Quincy Market, afternoon at the New England Aquarium, and Neptune Oyster for dinner.</p>
          </div>
          <div class="overview-day card conf">
            <div class="ov-date conf-date">Sep 24 · Day 3 · 💻 Conference</div>
            <h3>DevConf.US Day 1</h3>
            <p>Full day at Boston University for DevConf.US keynotes and technical sessions. Evening ice cream selfie at J.P. Licks on Newbury St.</p>
          </div>
          <div class="overview-day card conf">
            <div class="ov-date conf-date">Sep 25 · Day 4 · 💻 Conference</div>
            <h3>DevConf.US Day 2</h3>
            <p>Final day of DevConf.US — lightning talks and hallway track. Ice cream selfie at Toscanini's in Cambridge. Farewell dinner at Myers + Chang.</p>
          </div>
          <div class="overview-day card">
            <div class="ov-date">Sep 26 · Day 5</div>
            <h3>Museums & Departure</h3>
            <p>Morning at the Museum of Fine Arts, quick visit to the MIT campus in Cambridge, then head to Logan for departure.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DevConf.US -->
    <section class="section conf-section">
      <div class="container">
        <div class="conf-box">
          <div class="conf-icon">💻</div>
          <div class="conf-content">
            <p class="section-label">Featured Event</p>
            <h2>DevConf.US 2026</h2>
            <p>
              DevConf.US is a free, open community conference focused on open source, Linux, containers, Kubernetes,
              and developer tooling — organized by Red Hat. The 2026 edition takes place at <strong>Boston University</strong>
              on <strong>September 24–25</strong>.
            </p>
            <div class="conf-meta">
              <span>📍 Boston University, Boston MA</span>
              <span>📅 September 24–25, 2026</span>
              <span>🎟️ Free to attend</span>
            </div>
            <a href="https://www.devconf.us" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top:1rem;">
              Visit devconf.us →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Boston Travel Tips -->
    <section class="section section-alt">
      <div class="container">
        <p class="section-label">Local Knowledge</p>
        <h2>Boston Travel Tips</h2>
        <div class="tips-grid">
          <div class="tip-card card">
            <span class="tip-emoji">🚇</span>
            <h3>Getting Around</h3>
            <p>Boston's MBTA subway (the T) is the oldest in the US. Get a CharlieCard or tap with Apple/Google Pay. The Silver Line SL1 connects Logan Airport to South Station for just $2.40 — much cheaper than a taxi.</p>
          </div>
          <div class="tip-card card">
            <span class="tip-emoji">🌤️</span>
            <h3>September Weather</h3>
            <p>Expect 55–75°F (13–24°C) with warm days and cool evenings. September can bring rain — pack a light jacket. Locals joke that if you don't like Boston weather, wait five minutes.</p>
          </div>
          <div class="tip-card card">
            <span class="tip-emoji">💵</span>
            <h3>Tipping Culture</h3>
            <p>Tipping is standard and expected in Boston restaurants — 18–20% is the norm, 15% is considered low. Many locals tip more. For ride-share and delivery, 15–20% is appropriate.</p>
          </div>
          <div class="tip-card card">
            <span class="tip-emoji">🦞</span>
            <h3>Boston Food Scene</h3>
            <p>Don't miss the lobster rolls (hot buttered at Neptune Oyster is legendary), clam chowder at Quincy Market, and North End Italian food. Flour Bakery is a cult favorite for breakfast.</p>
          </div>
          <div class="tip-card card">
            <span class="tip-emoji">🏛️</span>
            <h3>Free Things</h3>
            <p>The Freedom Trail is completely free to walk self-guided. Beacon Hill, the Public Garden, Harvard Yard, and Faneuil Hall (exterior) are all free to explore. The city is very walkable.</p>
          </div>
          <div class="tip-card card">
            <span class="tip-emoji">📱</span>
            <h3>Stay Connected</h3>
            <p>Most US domestic phone plans cover Massachusetts with no extra charge. Hotel WiFi is generally reliable. Download Google Maps offline for Boston and Cambridge before you leave.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section cta-section">
      <div class="container cta-content">
        <h2>Ready to plan?</h2>
        <p>Explore Boston's hotels, restaurants, itinerary, and interactive map — or jump straight to the planning tools.</p>
        <div class="cta-buttons">
          <a href={`${base}/boston/`} class="btn btn-primary">Boston Guide →</a>
          <a href={`${base}/checklist/`} class="btn btn-secondary">Checklist</a>
          <a href={`${base}/budget/`} class="btn btn-secondary">Budget</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, var(--usa-red) 0%, #8b1a26 40%, var(--usa-blue) 100%);
    color: white;
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.07) 1px, transparent 0);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-bottom: 0.5rem;
  }

  .hero-title {
    color: white;
    margin-bottom: 0.5rem;
    font-size: clamp(2.5rem, 6vw, 4rem);
  }

  .hero-subtitle {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    margin-bottom: 1.75rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.25rem;
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    border: 1.5px solid rgba(255,255,255,0.6);
    background: transparent;
    color: white;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn-outline-white:hover { background: rgba(255,255,255,0.15); color: white; text-decoration: none; }

  .stats-section { padding: 2rem 0; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.85rem;
  }

  .stat-card {
    padding: 1.1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-icon { font-size: 1.6rem; }
  .stat-value { font-weight: 700; font-size: 1rem; color: var(--usa-blue); font-family: var(--font-serif); }
  .stat-label { font-size: 0.78rem; color: var(--gray-500); }

  .section-alt { background: white; }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .overview-day {
    padding: 1.1rem 1.25rem;
  }

  .overview-day h3 { font-size: 1rem; margin-bottom: 0.4rem; }
  .overview-day p { font-size: 0.85rem; color: var(--gray-700); line-height: 1.5; }

  .ov-date {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--usa-red);
    margin-bottom: 0.4rem;
  }

  .conf { border-left: 3px solid var(--usa-blue); }
  .conf-date { color: var(--usa-blue) !important; }

  .conf-section {
    background: var(--usa-blue-pale);
    border-top: 1px solid #c7c6e8;
    border-bottom: 1px solid #c7c6e8;
  }

  .conf-box {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .conf-icon { font-size: 3rem; flex-shrink: 0; }

  .conf-content h2 { margin-bottom: 0.5rem; }
  .conf-content p { color: var(--gray-700); margin-bottom: 0.75rem; line-height: 1.6; font-size: 0.95rem; }

  .conf-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--gray-700);
    font-weight: 500;
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .tip-card {
    padding: 1.25rem;
  }

  .tip-emoji { font-size: 1.75rem; display: block; margin-bottom: 0.6rem; }
  .tip-card h3 { font-size: 1rem; margin-bottom: 0.4rem; }
  .tip-card p { font-size: 0.85rem; color: var(--gray-700); line-height: 1.55; }

  .cta-section {
    background: linear-gradient(135deg, var(--usa-blue) 0%, var(--usa-red) 100%);
    color: white;
  }

  .cta-content {
    text-align: center;
    padding: 3rem 1.25rem;
  }

  .cta-content h2 { color: white; margin-bottom: 0.6rem; }
  .cta-content p { color: rgba(255,255,255,0.8); margin-bottom: 1.5rem; font-size: 1rem; max-width: 500px; margin-left: auto; margin-right: auto; }

  .cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .conf-box { flex-direction: column; gap: 1rem; }
    .stats-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
