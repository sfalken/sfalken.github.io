---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { budgetCategories } from '../data/budget';

const base = '/usa-trip';
const categoryOptions = budgetCategories.map(c => ({ id: c.id, label: `${c.icon} ${c.label}` }));
const today = new Date().toISOString().split('T')[0];
---

<Layout title="Log Expense — USA Trip 2026" description="Quick expense entry for the Boston trip.">
  <Nav />
  <main>
    <div class="log-hero">
      <div class="container">
        <p class="section-label">Quick Entry</p>
        <h1>Log Expense</h1>
        <p class="hero-sub">Track your spending on the go.</p>
      </div>
    </div>

    <section class="section">
      <div class="container log-container">

        <div class="card log-form-card">
          <form id="expense-form" class="log-form" novalidate>
            <div class="form-group">
              <label for="amount" class="form-label">Amount (USD)</label>
              <div class="amount-wrap">
                <span class="currency-prefix">$</span>
                <input
                  type="number"
                  id="amount"
                  name="amount"
                  class="form-input amount-input"
                  placeholder="0.00"
                  min="0"
                  step="0.01"
                  required
                  inputmode="decimal"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="category" class="form-label">Category</label>
              <select id="category" name="category" class="form-input" required>
                <option value="">— Select category —</option>
                {categoryOptions.map(opt => (
                  <option value={opt.id}>{opt.label}</option>
                ))}
              </select>
            </div>

            <div class="form-group">
              <label for="label" class="form-label">Description</label>
              <input
                type="text"
                id="label"
                name="label"
                class="form-input"
                placeholder="e.g. Neptune Oyster lobster roll"
                required
              />
            </div>

            <div class="form-group">
              <label for="date" class="form-label">Date</label>
              <input
                type="date"
                id="date"
                name="date"
                class="form-input"
                value={today}
                required
              />
            </div>

            <div id="form-error" class="form-error" style="display:none"></div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary btn-lg">Save Expense</button>
              <a href={`${base}/budget/`} class="btn btn-outline">View Budget →</a>
            </div>
          </form>

          <div id="success-msg" class="success-msg" style="display:none">
            <span class="success-icon">✓</span>
            <div>
              <strong>Expense saved!</strong>
              <p id="success-detail"></p>
            </div>
            <button id="add-another" class="btn btn-outline" style="margin-left:auto;">Add another</button>
          </div>
        </div>

        <!-- Recent 5 -->
        <div class="card recent-card">
          <div class="recent-header">
            <h3>Recent Expenses</h3>
            <a href={`${base}/budget/`} style="font-size:0.82rem;color:var(--usa-red);">View all →</a>
          </div>
          <div id="recent-list">
            <div class="empty-recent">No expenses yet.</div>
          </div>
        </div>

      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  const EXPENSE_KEY = 'usa-expenses';

  function loadExpenses() {
    try { return JSON.parse(localStorage.getItem(EXPENSE_KEY) || '[]'); } catch { return []; }
  }

  function saveExpenses(expenses) {
    localStorage.setItem(EXPENSE_KEY, JSON.stringify(expenses));
  }

  function formatUSD(n) {
    return '$' + Number(n).toFixed(2);
  }

  function renderRecent() {
    const expenses = loadExpenses();
    const listEl = document.getElementById('recent-list');
    if (!expenses.length) {
      listEl.innerHTML = '<div class="empty-recent">No expenses yet.</div>';
      return;
    }
    const recent = [...expenses].reverse().slice(0, 5);
    listEl.innerHTML = recent.map(e => `
      <div class="recent-item">
        <div class="ri-info">
          <span class="ri-label">${e.label || '—'}</span>
          <span class="ri-cat">${e.category || '—'} · ${e.date || '—'}</span>
        </div>
        <span class="ri-amount">${formatUSD(e.amount)}</span>
      </div>
    `).join('');
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderRecent();

    const form = document.getElementById('expense-form');
    const successMsg = document.getElementById('success-msg');
    const successDetail = document.getElementById('success-detail');
    const errorEl = document.getElementById('form-error');
    const addAnother = document.getElementById('add-another');

    form.addEventListener('submit', e => {
      e.preventDefault();
      const amount = parseFloat(document.getElementById('amount').value);
      const category = document.getElementById('category').value;
      const label = document.getElementById('label').value.trim();
      const date = document.getElementById('date').value;

      if (!amount || amount <= 0) {
        errorEl.textContent = 'Please enter a valid amount.';
        errorEl.style.display = 'block';
        return;
      }
      if (!category) {
        errorEl.textContent = 'Please select a category.';
        errorEl.style.display = 'block';
        return;
      }
      if (!label) {
        errorEl.textContent = 'Please enter a description.';
        errorEl.style.display = 'block';
        return;
      }

      errorEl.style.display = 'none';

      const requireAuth = window.piiRequireAuth || (cb => cb());
      requireAuth(() => {
        const expenses = loadExpenses();
        expenses.push({ amount, category, label, date, id: Date.now() });
        saveExpenses(expenses);
        successDetail.textContent = `${formatUSD(amount)} · ${label}`;
        form.style.display = 'none';
        successMsg.style.display = 'flex';
        renderRecent();
      });
    });

    addAnother.addEventListener('click', () => {
      form.reset();
      // Reset date to today
      document.getElementById('date').value = new Date().toISOString().split('T')[0];
      form.style.display = 'block';
      successMsg.style.display = 'none';
    });
  });
</script>

<style>
  .log-hero {
    background: linear-gradient(135deg, var(--usa-blue) 0%, #2a2950 100%);
    color: white;
    padding: 2.5rem 0 2rem;
  }
  .log-hero .section-label { color: rgba(255,255,255,0.65); }
  .log-hero h1 { color: white; margin-bottom: 0.4rem; }
  .hero-sub { color: rgba(255,255,255,0.75); }

  .log-container {
    max-width: 540px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .log-form-card { padding: 1.5rem; }

  .log-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }

  .form-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gray-700);
    letter-spacing: 0.02em;
  }

  .form-input {
    width: 100%;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--gray-900);
    background: white;
    transition: border-color 0.15s;
    -webkit-appearance: none;
  }
  .form-input:focus {
    outline: none;
    border-color: var(--usa-red);
    box-shadow: 0 0 0 3px rgba(178,34,52,0.1);
  }

  .amount-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .currency-prefix {
    position: absolute;
    left: 0.9rem;
    font-weight: 600;
    color: var(--gray-500);
    pointer-events: none;
    z-index: 1;
  }

  .amount-input { padding-left: 1.75rem; }

  .form-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    border-radius: var(--radius);
    padding: 0.6rem 0.9rem;
    font-size: 0.85rem;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }

  .btn-lg { padding: 0.75rem 1.5rem; font-size: 1rem; }

  .success-msg {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    flex-wrap: wrap;
  }

  .success-icon {
    width: 36px;
    height: 36px;
    background: #22c55e;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .success-msg strong { display: block; color: #15803d; }
  .success-msg p { font-size: 0.85rem; color: #166534; margin-top: 0.15rem; }

  .recent-card { overflow: hidden; }

  .recent-header {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--gray-100);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .recent-header h3 { font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600; }

  .recent-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 1.25rem;
    border-bottom: 1px solid var(--gray-50);
  }
  .recent-item:last-child { border-bottom: none; }

  .ri-info { flex: 1; }
  .ri-label { display: block; font-size: 0.88rem; color: var(--gray-900); font-weight: 500; }
  .ri-cat { display: block; font-size: 0.75rem; color: var(--gray-500); margin-top: 0.1rem; }
  .ri-amount { font-size: 0.9rem; font-weight: 700; color: var(--usa-red); }

  .empty-recent {
    padding: 1.25rem;
    text-align: center;
    color: var(--gray-400);
    font-size: 0.85rem;
  }
</style>
